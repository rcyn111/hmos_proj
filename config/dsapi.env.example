# ============================================================
# DSAPI / DeepSeek Anthropic 兼容接口 — 配置示例
# ============================================================
#
# ⚠️  重要：本文件是示例，不含真实 API key。
#     真实 key 只应设置在你本机的终端环境变量中。
#     不要把真实 key 写进项目任何文件中！
#
# 使用方式：
#   方法 1（推荐）：在终端中逐行执行以下 export 命令
#   方法 2：将以下内容添加到 ~/.zshrc 或 ~/.bashrc，然后 source 一下
#
# 获取 DeepSeek API key：https://platform.deepseek.com/api_keys
# ============================================================

# DeepSeek Anthropic 兼容接口地址
export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"

# 你的 DeepSeek API key（替换为你自己的 key）
export ANTHROPIC_AUTH_TOKEN="your_dsapi_key_here"

# 默认模型（根据 DeepSeek 提供的模型名称填写）
export ANTHROPIC_MODEL="deepseek-v4-pro"

# Opus 级别模型（用于复杂任务）
export ANTHROPIC_DEFAULT_OPUS_MODEL="deepseek-v4-pro"

# Sonnet 级别模型（用于一般任务）
export ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek-v4-pro"

# ============================================================
# 使用前检查清单：
# ============================================================
#
# [ ] 已在 https://platform.deepseek.com 注册并获取 API key
# [ ] 已将 your_dsapi_key_here 替换为真实 key
# [ ] 已在终端中 source 了这些环境变量
# [ ] 已确认本文件不会被提交到 Git（已在 .gitignore 中）
# [ ] 没有将真实 key 复制到项目的其他文件中
# ============================================================
